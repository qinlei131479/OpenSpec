# --- Docker Image Configuration ---
DOCKER_REGISTRY=registry.cn-guangzhou.aliyuncs.com/zzykj/
TAG=20260210

# --- Database Configuration (Shared) ---
MYSQL_HOST=mysql
MYSQL_PORT=3306
MYSQL_ROOT_PASSWORD=your_root_password
MYSQL_USER=your_db_user
MYSQL_PASSWORD=your_db_password

# Backend Configuration
BACKEND_PORT=8080
SPRING_PROFILES_ACTIVE=prod
# MySQL Database Configuration
MYSQL_DATABASE=doc_generator
SPRING_DATASOURCE_URL=jdbc:mysql://mysql:3306/doc_generator?useUnicode=true&characterEncoding=utf8&useSSL=false&allowPublicKeyRetrieval=true

# AI Agent Configuration
AGENT_PORT=5000
APP_LOG_LEVEL=INFO

# RAGFlow Configuration (Update with your actual values)
RAGFLOW_API_KEY=your_ragflow_api_key
RAGFLOW_BASE_URL=https://your-ragflow-host.com
TEST_PROJECT_ID=your_test_project_id

# DashScope Configuration (for LLM, update with your actual key)
DASHSCOPE_API_KEY=your_dashscope_api_key

# Langfuse Configuration (for tracing, optional)
LANGFUSE_SECRET_KEY=your_langfuse_secret_key
LANGFUSE_PUBLIC_KEY=your_langfuse_public_key
LANGFUSE_BASE_URL=http://your-langfuse-host.com
PROMPT_LABEL=latest

# --- License Configuration ---
LICENSE_FILE=../../apps/backend/license.lic

# --- Web Frontend ---
WEB_PORT=80

# 知识库配置--不同环境 id 不同，根据需要调整
DEFAULT_CASE_KB_IDS=["your_case_kb_id_1", "your_case_kb_id_2", "your_case_kb_id_3"]
DEFAULT_STAND_KB_IDS=["your_stand_kb_id_1", "your_stand_kb_id_2"]

# 个人模版知识库名称（用于上传个人文档模版和CAD模版）
PERSONAL_TEMPLATE_KB_NAME=personal-template

# Workflow 配置 - Token 和长度限制
MAX_TOOL_MESSAGES=30           # 上下文中最多保留的 ToolMessage 数量
MAX_TOTAL_TOKENS=30000         # 最大 Token 数（预留 2k tokens 给响应）
MIN_CONTENT_THRESHOLD=1000     # 检索内容最小阈值（字符数）

# Workflow 配置 - 循环控制
MAX_RESEARCH_LOOPS=3           # Researcher 最大循环次数
MAX_AUDIT_LOOPS=1              # Auditor 最大循环次数

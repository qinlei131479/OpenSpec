DOCKER_REGISTRY=registry.cn-guangzhou.aliyuncs.com/zzykj/
TAG=20260212

# --- PostgreSQL Database Configuration ---
POSTGRES_HOST=postgres
POSTGRES_PORT=5433
POSTGRES_DB=doc_generator
POSTGRES_USER=archspec
POSTGRES_PASSWORD=your_postgres_password

# --- Backend Service ---
SPRING_PROFILES_ACTIVE=prod
BACKEND_PORT=8080
# Backend DB Connection (Internal)
SPRING_DATASOURCE_URL=jdbc:postgresql://${POSTGRES_HOST}:5432/${POSTGRES_DB}?currentSchema=public
SPRING_DATASOURCE_USERNAME=${POSTGRES_USER}
SPRING_DATASOURCE_PASSWORD=${POSTGRES_PASSWORD}

# --- JWT 配置（Java 后端和 Python Agent 共享） ---
JWT_SECRET=your_jwt_secret_key

# --- AI Agent Service ---
APP_LOG_LEVEL=DEBUG
AGENT_PORT=5000
# Agent PostgreSQL Connection
POSTGRES_URL=postgresql://${POSTGRES_USER}:${POSTGRES_PASSWORD}@${POSTGRES_HOST}:5432/${POSTGRES_DB}


# --- 阿里云 Dashscope API Key ---
# 注册地址: https://dashscope.console.aliyun.com/
DASHSCOPE_API_KEY=your_dashscope_api_key

# --- RAGFlow 配置 ---
# 注册 RAGFlow 后获取 API Key: https://github.com/infiniflow/ragflow
RAGFLOW_API_KEY=your_ragflow_api_key
RAGFLOW_BASE_URL=http://your-ragflow-host:9380

# 知识库配置--不同环境 id 不同，根据需要调整
DEFAULT_CASE_KB_IDS=["your_case_kb_id_1", "your_case_kb_id_2"]
DEFAULT_STAND_KB_IDS=["your_standard_kb_id_1", "your_standard_kb_id_2"]


# --- Langfuse 可观测性（可选） ---
# 注册地址: https://langfuse.com/ 或自部署
LANGFUSE_SECRET_KEY=your_langfuse_secret_key
LANGFUSE_PUBLIC_KEY=your_langfuse_public_key
LANGFUSE_BASE_URL=http://your-langfuse-host:3000
PROMPT_LABEL=latest


# Workflow 配置 - Token 和长度限制
MAX_TOOL_MESSAGES=30           # 上下文中最多保留的 ToolMessage 数量
MAX_TOTAL_TOKENS=30000         # 最大 Token 数（预留 2k tokens 给响应）
MIN_CONTENT_THRESHOLD=1000     # 检索内容最小阈值（字符数）

# Workflow 配置 - 循环控制
MAX_RESEARCH_LOOPS=3           # Researcher 最大循环次数
MAX_AUDIT_LOOPS=2              # Auditor 最大循环次数

# --- Web Frontend ---
WEB_PORT=80
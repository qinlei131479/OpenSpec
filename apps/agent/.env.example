MYSQL_HOST="localhost"
MYSQL_USER="root"
MYSQL_PASSWORD="rootpass123"
MYSQL_DATABASE="doc_generator"

# PostgreSQL Memory Database (for LangGraph Checkpointer)
POSTGRES_URL="postgresql://openspec:openspec_doc_pass@localhost:5433/doc_generator"

RAGFLOW_API_KEY="your-ragflow-api-key"
RAGFLOW_BASE_URL="http://your-ragflow-host:9380"

DASHSCOPE_API_KEY="your-dashscope-api-key"
APP_LOG_LEVEL=INFO

# langfuse 配置 (optional)
LANGFUSE_SECRET_KEY="your-langfuse-secret-key"
LANGFUSE_PUBLIC_KEY="your-langfuse-public-key"
LANGFUSE_BASE_URL="http://your-langfuse-host"

PROMPT_LABEL=latest

# 知识库配置
DEFAULT_CASE_KB_IDS=[]
DEFAULT_STAND_KB_IDS=[]

# Workflow 配置 - Token 和长度限制
MAX_TOOL_MESSAGES=30           # 上下文中最多保留的 ToolMessage 数量
MAX_TOTAL_TOKENS=30000         # 最大 Token 数（预留 2k tokens 给响应）
MIN_CONTENT_THRESHOLD=1000     # 检索内容最小阈值（字符数）

# Workflow 配置 - 循环控制
MAX_RESEARCH_LOOPS=3           # Researcher 最大循环次数
MAX_AUDIT_LOOPS=1              # Auditor 最大循环次数

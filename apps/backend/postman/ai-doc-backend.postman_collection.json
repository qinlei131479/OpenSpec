{
  "info": {
    "name": "AI Doc Backend - REST",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json",
    "_postman_id": "1d2f3a6b-9a0b-4d5c-bf2b-adef0c0a0001"
  },
  "variable": [
    { "key": "host", "value": "localhost" },
    { "key": "port", "value": "8080" },
    { "key": "basePath", "value": "/api/v1" },
    { "key": "documentId", "value": "DOC-100001" },
    { "key": "blockId", "value": "BLK-100001" }
  ],
  "item": [
    {
      "name": "Documents - List",
      "request": {
        "method": "GET",
        "url": {
          "raw": "http://localhost:8080/api/v1/documents?page=1&pageSize=20",
          "protocol": "http",
          "host": ["localhost"],
          "port": "8080",
          "path": ["/api/v1", "documents"],
          "query": [
            {"key":"page","value":"1"},
            {"key":"pageSize","value":"20"}
          ]
        }
      }
    },
    {
      "name": "Documents - Create",
      "request": {
        "method": "POST",
        "header": [ {"key":"Content-Type","value":"application/json"} ],
        "url": {
          "raw": "http://localhost:8080/api/v1/documents",
          "protocol": "http",
          "host": ["localhost"],
          "port": "8080",
          "path": ["/api/v1", "documents"]
        },
        "body": {
          "mode": "raw",
          "raw": "{\n  \"name\": \"新建文档\",\n  \"projectInfo\": {\n    \"project\": \"AI Doc Demo\",\n    \"env\": \"dev\"\n  }\n}"
        }
      }
    },
    {
      "name": "Documents - Rename",
      "request": {
        "method": "PATCH",
        "header": [ {"key":"Content-Type","value":"application/json"} ],
        "url": {
          "raw": "http://localhost:8080/api/v1/documents/{{documentId}}/rename",
          "protocol": "http",
          "host": ["localhost"],
          "port": "8080",
          "path": ["/api/v1", "documents", "{{documentId}}", "rename"]
        },
        "body": {
          "mode": "raw",
          "raw": "{\n  \"name\": \"文档新名称\"\n}"
        }
      }
    },
    {
      "name": "Documents - Delete",
      "request": {
        "method": "DELETE",
        "url": {
          "raw": "http://localhost:8080/api/v1/documents/{{documentId}}",
          "protocol": "http",
          "host": ["localhost"],
          "port": "8080",
          "path": ["/api/v1", "documents", "{{documentId}}"]
        }
      }
    },
    {
      "name": "Blocks - List",
      "request": {
        "method": "GET",
        "url": {
          "raw": "http://localhost:8080/api/v1/documents/{{documentId}}/blocks?page=1&pageSize=20",
          "protocol": "http",
          "host": ["localhost"],
          "port": "8080",
          "path": ["/api/v1", "documents", "{{documentId}}", "blocks"],
          "query": [
            {"key":"page","value":"1"},
            {"key":"pageSize","value":"20"}
          ]
        }
      }
    },
    {
      "name": "Blocks - Create",
      "request": {
        "method": "POST",
        "header": [ {"key":"Content-Type","value":"application/json"} ],
        "url": {
          "raw": "http://localhost:8080/api/v1/documents/{{documentId}}/blocks",
          "protocol": "http",
          "host": ["localhost"],
          "port": "8080",
          "path": ["/api/v1", "documents", "{{documentId}}", "blocks"]
        },
        "body": {
          "mode": "raw",
          "raw": "{\n  \"block_type\": \"paragraph\",\n  \"content\": \"这是一段新内容\",\n  \"level\": 1,\n  \"parent_id\": null,\n  \"order_key\": \"0100\"\n}"
        }
      }
    },
    {
      "name": "Blocks - Get",
      "request": {
        "method": "GET",
        "url": {
          "raw": "http://localhost:8080/api/v1/documents/{{documentId}}/blocks/{{blockId}}",
          "protocol": "http",
          "host": ["localhost"],
          "port": "8080",
          "path": ["/api/v1", "documents", "{{documentId}}", "blocks", "{{blockId}}"]
        }
      }
    },
    {
      "name": "Blocks - Update Content",
      "request": {
        "method": "PUT",
        "header": [ {"key":"Content-Type","value":"application/json"} ],
        "url": {
          "raw": "http://localhost:8080/api/v1/documents/{{documentId}}/blocks/{{blockId}}",
          "protocol": "http",
          "host": ["localhost"],
          "port": "8080",
          "path": ["/api/v1", "documents", "{{documentId}}", "blocks", "{{blockId}}"]
        },
        "body": {
          "mode": "raw",
          "raw": "{\n  \"content\": \"更新后的内容\"\n}"
        }
      }
    },
    {
      "name": "Blocks - Rename",
      "request": {
        "method": "PATCH",
        "header": [ {"key":"Content-Type","value":"application/json"} ],
        "url": {
          "raw": "http://localhost:8080/api/v1/documents/{{documentId}}/blocks/{{blockId}}/rename",
          "protocol": "http",
          "host": ["localhost"],
          "port": "8080",
          "path": ["/api/v1", "documents", "{{documentId}}", "blocks", "{{blockId}}", "rename"]
        },
        "body": {
          "mode": "raw",
          "raw": "{\n  \"name\": \"新的标题\"\n}"
        }
      }
    },
    {
      "name": "Blocks - Delete",
      "request": {
        "method": "DELETE",
        "url": {
          "raw": "http://localhost:8080/api/v1/documents/{{documentId}}/blocks/{{blockId}}",
          "protocol": "http",
          "host": ["localhost"],
          "port": "8080",
          "path": ["/api/v1", "documents", "{{documentId}}", "blocks", "{{blockId}}"]
        }
      }
    }
  ]
}


